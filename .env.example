# --- Database ---
# Local dev (docker-compose): postgres://golden_tine:golden_tine@localhost:5432/golden_tine
# Production: Neon connection string (use the pooled/-pooler connection string)
DATABASE_URL=
# Host port docker-compose maps Postgres to (change if 5432 is already taken
# by another local Postgres). Match it in DATABASE_URL above.
POSTGRES_HOST_PORT=5432

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional) — console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Registration ---
# Keep "false" in production. The bootstrap account below is created by
# `pnpm db:seed` — public registration should stay closed for a personal app.
ALLOW_PUBLIC_SIGNUP=false
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Cron (Vercel Cron → /api/cron/daily) ---
# Generate with: openssl rand -base64 24
# Set the SAME value in Vercel project env vars; Vercel Cron sends it as a
# Bearer token so the route can reject unauthenticated calls.
CRON_SECRET=

# --- File storage (Cloudflare R2 — wired up in Phase 3) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Cache / rate limit (Upstash Redis — wired up in Phase 2) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
